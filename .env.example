# ─── Database ────────────────────────────────────────────────────────────
# Local dev: leave both blank — falls back to ./data/app.db (SQLite file).
# Production (Vercel): use Turso — https://turso.tech
#   turso db create progress-bbx
#   turso db show progress-bbx --url        -> TURSO_DATABASE_URL
#   turso db tokens create progress-bbx     -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── Auth ────────────────────────────────────────────────────────────────
# Manager credentials. CHANGE BOTH IN PRODUCTION.
AUTH_USERNAME=admin
AUTH_PASSWORD=progress2026

# Used to sign the session cookie. 32+ random chars.
# Generate: `openssl rand -hex 32`
SESSION_SECRET=dev-secret-change-me-please
